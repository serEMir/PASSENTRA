CRE_ETH_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Required by run-demo.sh (mapped via secrets.yaml)
WORLD_ID_VERIFIER_API_KEY_ALL=replace-me
COMPLIANCE_ADAPTER_API_KEY_ALL=replace-me
